<Application x:Class="PSAutomationToolkit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                            PrimaryColor="Blue"
                                            SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App-wide colors -->
            <SolidColorBrush x:Key="AppBackground"    Color="#1E1E2E"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#13131F"/>
            <SolidColorBrush x:Key="CardBackground"   Color="#2A2A3E"/>
            <SolidColorBrush x:Key="AccentBlue"       Color="#4FC3F7"/>
            <SolidColorBrush x:Key="AccentGreen"      Color="#4CAF50"/>
            <SolidColorBrush x:Key="AccentOrange"     Color="#FF9800"/>
            <SolidColorBrush x:Key="TextPrimary"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary"    Color="#B0B0C8"/>
            <SolidColorBrush x:Key="BorderColor"      Color="#3A3A5C"/>
            <SolidColorBrush x:Key="HoverBackground"  Color="#33334D"/>
            <SolidColorBrush x:Key="SelectedBackground" Color="#1A3A5C"/>

            <!-- Complexity badge colors -->
            <SolidColorBrush x:Key="EntryBadge"  Color="#2E7D32"/>
            <SolidColorBrush x:Key="MidBadge"    Color="#E65100"/>
            <SolidColorBrush x:Key="SeniorBadge" Color="#6A1B9A"/>

            <!-- Global styles -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background"   Value="{StaticResource CardBackground}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding"      Value="16"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="11"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
                <Setter Property="LetterSpacing" Value="1.5"/>
                <Setter Property="Margin"       Value="0,0,0,8"/>
            </Style>

            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
                <Setter Property="Padding"      Value="12,8"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
