<Window x:Class="PSAutomationToolkit.Views.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Log — PS Automation Toolkit Pro"
        Height="500" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackground}"
        TextElement.Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <TextBlock Text="📋  Activity Log" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="LogPathText" DockPanel.Dock="Right"
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Log Content -->
        <Border Grid.Row="1" Margin="16,12,16,4"
                Background="{StaticResource CardBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8">
            <ScrollViewer x:Name="LogScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="4">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="#B0C4DE"
                         BorderThickness="0"
                         Padding="12"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Hidden"
                         HorizontalScrollBarVisibility="Hidden"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SidebarBackground}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <Button DockPanel.Dock="Right" Click="Close_Click"
                        Style="{StaticResource IconButtonStyle}"
                        Padding="16,8">
                    <TextBlock Text="Close" FontSize="13"/>
                </Button>
                <Button DockPanel.Dock="Right" Click="OpenLogFile_Click"
                        Style="{StaticResource IconButtonStyle}"
                        Margin="0,0,8,0" Padding="16,8">
                    <TextBlock Text="Open Log File" FontSize="13"/>
                </Button>
                <Button DockPanel.Dock="Right" Click="Refresh_Click"
                        Style="{StaticResource IconButtonStyle}"
                        Margin="0,0,8,0" Padding="16,8">
                    <TextBlock Text="↻ Refresh" FontSize="13"/>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
