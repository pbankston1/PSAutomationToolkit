<Window x:Class="PSAutomationToolkit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PSAutomationToolkit.ViewModels"
        Title="PS Automation Toolkit Pro"
        Height="860" Width="1400"
        MinHeight="640" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        TextElement.Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

  <Window.Resources>

    <!-- Category list item -->
    <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="0"/>
      <Setter Property="Margin"          Value="4,1"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="10,7"
                    BorderThickness="2,0,0,0" BorderBrush="Transparent">
              <ContentPresenter HorizontalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBackground}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Script list item -->
    <Style x:Key="ScriptItemStyle" TargetType="ListBoxItem">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="0"/>
      <Setter Property="Margin"          Value="4,3"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="12,10"
                    BorderThickness="1" BorderBrush="Transparent">
              <ContentPresenter HorizontalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderColor}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectedBackground}"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Converters -->
    <vm:ComplexityColorConverter   x:Key="ComplexityColorConverter"/>
    <vm:BoolToVisibilityConverter  x:Key="BoolVis"/>
    <vm:BoolToVisibilityInverseConverter x:Key="BoolVisInv"/>
    <vm:NullToVisibilityConverter  x:Key="NullVis"    ShowWhenNull="True"/>
    <vm:NullToVisibilityConverter  x:Key="NotNullVis" ShowWhenNull="False"/>
    <vm:StringToVisibilityConverter x:Key="StrVis"/>

    <!-- Primary action button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background"   Value="#0078D4"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#006CBE"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox style -->
    <Style x:Key="FilterComboStyle" TargetType="ComboBox">
      <Setter Property="Background"   Value="{StaticResource CardBackground}"/>
      <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
      <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"      Value="8,4"/>
      <Setter Property="FontSize"     Value="12"/>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="56"/>   <!-- Title bar -->
      <RowDefinition Height="*"/>    <!-- Content -->
      <RowDefinition Height="30"/>   <!-- Status bar -->
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TITLE BAR                                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{StaticResource SidebarBackground}"
            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="270"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Logo -->
        <StackPanel Grid.Column="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="14,0">
          <Border Width="36" Height="36" CornerRadius="9"
                  Background="#0078D4" Margin="0,0,10,0">
            <TextBlock Text="PS" FontSize="14" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="PS Automation Toolkit" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="PRO  ·  v2.0" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource AccentBlue}" LetterSpacing="1.5"/>
          </StackPanel>
        </StackPanel>

        <!-- Search bar -->
        <Border Grid.Column="1" Background="{StaticResource CardBackground}"
                CornerRadius="7" Margin="12,10"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                       VerticalAlignment="Center" Margin="10,0,6,0"
                       Foreground="{StaticResource TextSecondary}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource TextPrimary}"
                     VerticalAlignment="Center" FontSize="13"
                     VerticalContentAlignment="Center">
              <TextBox.Style>
                <Style TargetType="TextBox">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="TextBox">
                        <Grid>
                          <TextBlock Text="Search 84 scripts across 18 categories…"
                                     Foreground="{StaticResource TextSecondary}"
                                     FontSize="13" VerticalAlignment="Center"
                                     Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent},
                                                  Converter={StaticResource StrVis},
                                                  ConverterParameter=Inverse}"/>
                          <ScrollViewer x:Name="PART_ContentHost"
                                        Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </TextBox.Style>
            </TextBox>
            <Button Grid.Column="2" Command="{Binding ClearSearchCommand}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Margin="0,0,6,0"
                    Visibility="{Binding SearchQuery, Converter={StaticResource StrVis}}">
              <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
            </Button>
          </Grid>
        </Border>

        <!-- Header buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="0,0,14,0">
          <!-- Stats pill -->
          <Border Background="{StaticResource CardBackground}"
                  CornerRadius="20" Padding="12,5" Margin="0,0,10,0"
                  BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                <Run Text="{Binding TotalScripts, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{StaticResource AccentBlue}"/>
                <Run Text=" scripts  ·  "/>
                <Run Text="{Binding TotalCategories, Mode=OneWay}" FontWeight="Bold"
                     Foreground="{StaticResource AccentBlue}"/>
                <Run Text=" categories"/>
              </TextBlock>
            </StackPanel>
          </Border>
          <Button Style="{StaticResource IconButtonStyle}"
                  Click="OpenSettings_Click" Margin="0,0,8,0"
                  ToolTip="Settings" Padding="12,7">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="⚙ " FontSize="13"/>
              <TextBlock Text="Settings" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource IconButtonStyle}"
                  Click="OpenLog_Click" ToolTip="Activity log" Padding="12,7">
            <TextBlock Text="📋 Log" FontSize="12"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT  (sidebar | scripts | code)                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="270" MinWidth="200" MaxWidth="340"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="320" MinWidth="240" MaxWidth="440"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ── LEFT SIDEBAR: Categories ─────────────────────────────── -->
      <Border Grid.Column="0" Background="{StaticResource SidebarBackground}"
              BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Header -->
          <Border Grid.Row="0" Padding="14,12,14,8"
                  BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <StackPanel>
              <TextBlock Text="CATEGORIES" Style="{StaticResource SectionHeaderStyle}"/>
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                <Run Text="{Binding Categories.Count, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource AccentBlue}"/>
                <Run Text=" domains  ·  "/>
                <Run Text="{Binding TotalScripts, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource AccentBlue}"/>
                <Run Text=" total scripts"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Category list -->
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Categories}"
                   SelectedItem="{Binding SelectedCategory}"
                   Background="Transparent" BorderThickness="0"
                   Padding="6,4"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ItemContainerStyle="{StaticResource CategoryItemStyle}"
                   VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Icon}"
                             FontSize="15" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Name}"
                             FontSize="12" VerticalAlignment="Center"
                             TextWrapping="Wrap" Margin="6,0,4,0"
                             Foreground="{StaticResource TextPrimary}"/>
                  <Border Grid.Column="2" Background="{StaticResource HoverBackground}"
                          CornerRadius="10" Padding="5,2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Count}" FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlue}"
                               HorizontalAlignment="Center"/>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Sidebar footer -->
          <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}"
                  BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel>
              <TextBlock FontSize="10" Foreground="{StaticResource TextSecondary}"
                         TextWrapping="Wrap">
                <Run Text="PS Automation Toolkit Pro  |  v2.0"/>
              </TextBlock>
              <TextBlock FontSize="10" Foreground="{StaticResource TextSecondary}"
                         Margin="0,2,0,0">
                <Run Text="18 domains  ·  84+ scripts"/>
              </TextBlock>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="4"
                    Background="{StaticResource BorderColor}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

      <!-- ── CENTER PANEL: Script List ───────────────────────────── -->
      <Border Grid.Column="2" Background="{StaticResource AppBackground}"
              BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- filters -->
            <RowDefinition Height="*"/>      <!-- list -->
          </Grid.RowDefinitions>

          <!-- Panel header -->
          <Border Grid.Row="0" Padding="14,11,14,8"
                  BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel>
              <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="SCRIPTS" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                  <Run Text="{Binding FilteredScripts.Count, Mode=OneWay}" FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBlue}"/>
                  <Run Text=" scripts shown"/>
                </TextBlock>
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- Filters bar -->
          <Border Grid.Row="1" Padding="10,8"
                  BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                  Background="{StaticResource SidebarBackground}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <!-- Complexity filter -->
              <StackPanel Grid.Column="0">
                <TextBlock Text="LEVEL" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4" LetterSpacing="1"/>
                <ComboBox ItemsSource="{Binding ComplexityFilters}"
                          SelectedItem="{Binding SelectedComplexity}"
                          Style="{StaticResource FilterComboStyle}"/>
              </StackPanel>
              <!-- Tag filter -->
              <StackPanel Grid.Column="2">
                <TextBlock Text="TAG" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4" LetterSpacing="1"/>
                <ComboBox ItemsSource="{Binding AvailableTags}"
                          SelectedItem="{Binding SelectedTag}"
                          Style="{StaticResource FilterComboStyle}"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Script items -->
          <ListBox Grid.Row="2"
                   ItemsSource="{Binding FilteredScripts}"
                   SelectedItem="{Binding SelectedScript}"
                   Background="Transparent" BorderThickness="0"
                   Padding="6,4"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ItemContainerStyle="{StaticResource ScriptItemStyle}"
                   VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <!-- Name + badge -->
                  <DockPanel Grid.Row="0">
                    <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2"
                            Background="{Binding ComplexityLevel,
                                         Converter={StaticResource ComplexityColorConverter}}">
                      <TextBlock Text="{Binding ComplexityLevel}"
                                 FontSize="9" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="{Binding TaskName}" FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                  </DockPanel>

                  <!-- Description -->
                  <TextBlock Grid.Row="1" Text="{Binding Description}"
                             FontSize="11.5" Foreground="{StaticResource TextSecondary}"
                             TextWrapping="Wrap" MaxHeight="36"
                             TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                  <!-- Tags -->
                  <ItemsControl Grid.Row="2" ItemsSource="{Binding Tags}" Margin="0,5,0,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{StaticResource HoverBackground}"
                                CornerRadius="4" Padding="5,1" Margin="0,0,3,2">
                          <TextBlock Text="{Binding}" FontSize="9.5"
                                     Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3" Width="4"
                    Background="{StaticResource BorderColor}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

      <!-- ── RIGHT PANEL: Code Output ──────────────────────────────── -->
      <Grid Grid.Column="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>   <!-- script details card -->
          <RowDefinition Height="Auto"/>   <!-- action buttons -->
          <RowDefinition Height="*"/>      <!-- code editor -->
        </Grid.RowDefinitions>

        <!-- ── Script Details Card ── -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="14,14,14,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Empty state -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding SelectedScript, Converter={StaticResource NullVis}}"
                        HorizontalAlignment="Center" Margin="0,8">
              <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center" Opacity="0.3"/>
              <TextBlock Text="Select a Script" FontSize="17" FontWeight="SemiBold"
                         Foreground="{StaticResource TextSecondary}"
                         HorizontalAlignment="Center" Margin="0,6,0,2"/>
              <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}"
                         HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap">
                Choose a category from the left, pick a script,
                then click Generate Code.
              </TextBlock>
            </StackPanel>

            <!-- Script details -->
            <Grid Grid.Row="0"
                  Visibility="{Binding SelectedScript, Converter={StaticResource NotNullVis}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding SelectedScript.TaskName}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedScript.Category}"
                           FontSize="11" Foreground="{StaticResource AccentBlue}"
                           Margin="0,3,0,0"/>
                <TextBlock Text="{Binding SelectedScript.Description}"
                           FontSize="12.5" Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
              </StackPanel>
              <!-- Complexity badge -->
              <Border Grid.Column="1" CornerRadius="8" Padding="12,6"
                      Margin="12,0,0,0" VerticalAlignment="Top"
                      Background="{Binding SelectedScript.ComplexityLevel,
                                   Converter={StaticResource ComplexityColorConverter}}">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedScript.ComplexityLevel}"
                             FontSize="12" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="LEVEL" FontSize="8" Foreground="White"
                             Opacity="0.8" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
            </Grid>

            <!-- Generate button -->
            <Button Grid.Row="1"
                    Command="{Binding GenerateCodeCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Padding="22,11" FontSize="14" FontWeight="SemiBold"
                    HorizontalAlignment="Left" Margin="0,12,0,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶  " FontSize="13"/>
                <TextBlock Text="Generate Code"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <!-- ── Action Buttons Row ── -->
        <Border Grid.Row="1" Margin="14,0,14,8">
          <WrapPanel Orientation="Horizontal">
            <Button Command="{Binding CopyToClipboardCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Margin="0,0,8,0" Padding="12,7"
                    ToolTip="Copy to clipboard  (Ctrl+C)">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋 " FontSize="12"/>
                <TextBlock Text="Copy" FontSize="12"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding SaveAsPs1Command}"
                    Style="{StaticResource IconButtonStyle}"
                    Margin="0,0,8,0" Padding="12,7"
                    ToolTip="Save as PowerShell script (.ps1)">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="💾 " FontSize="12"/>
                <TextBlock Text="Save .ps1" FontSize="12"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding SaveAsTxtCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Margin="0,0,8,0" Padding="12,7"
                    ToolTip="Export as text file (.txt)">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="📄 " FontSize="12"/>
                <TextBlock Text="Export .txt" FontSize="12"/>
              </StackPanel>
            </Button>
            <!-- Char count pill -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="20" Padding="10,4"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsCodeGenerated, Converter={StaticResource BoolVis}}">
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                <Run Text="{Binding GeneratedCode.Length, Mode=OneWay}"/>
                <Run Text=" chars"/>
              </TextBlock>
            </Border>
          </WrapPanel>
        </Border>

        <!-- ── Code Editor ── -->
        <Border Grid.Row="2" Margin="14,0,14,12"
                Background="{StaticResource CardBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="36"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Editor title bar (traffic lights style) -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1" Padding="14,0">
              <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                  <Ellipse Width="11" Height="11" Fill="#FF5F57" Margin="0,0,6,0"/>
                  <Ellipse Width="11" Height="11" Fill="#FFBD2E" Margin="0,0,6,0"/>
                  <Ellipse Width="11" Height="11" Fill="#28CA41" Margin="0,0,14,0"/>
                  <TextBlock Text="PowerShell" FontSize="11.5"
                             Foreground="{StaticResource TextSecondary}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Visibility="{Binding SelectedScript, Converter={StaticResource NotNullVis}}">
                  <Run Text="{Binding SelectedScript.Category, Mode=OneWay}"/>
                </TextBlock>
              </DockPanel>
            </Border>

            <!-- Empty placeholder -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsCodeGenerated, Converter={StaticResource BoolVisInv}}">
              <TextBlock Text="⚡" FontSize="52" HorizontalAlignment="Center" Opacity="0.15"/>
              <TextBlock Text="No code generated yet"
                         FontSize="14" Foreground="{StaticResource TextSecondary}"
                         HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.5"/>
              <TextBlock Text="Pick a script → Generate Code"
                         FontSize="12" Foreground="{StaticResource TextSecondary}"
                         HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.35"/>
            </StackPanel>

            <!-- Code text box -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsCodeGenerated, Converter={StaticResource BoolVis}}">
              <TextBox Text="{Binding GeneratedCode, Mode=OneWay}"
                       IsReadOnly="True"
                       TextWrapping="NoWrap"
                       AcceptsReturn="True"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12.5"
                       Background="Transparent"
                       Foreground="#D4D4D4"
                       BorderThickness="0"
                       Padding="16,14"
                       VerticalScrollBarVisibility="Hidden"
                       HorizontalScrollBarVisibility="Hidden"
                       SelectionBrush="{StaticResource AccentBlue}"
                       CaretBrush="{StaticResource AccentBlue}"/>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- STATUS BAR                                                   -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Background="{StaticResource SidebarBackground}"
            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
      <DockPanel Margin="14,0">
        <TextBlock DockPanel.Dock="Left"
                   Text="{Binding StatusMessage}"
                   FontSize="11.5" Foreground="{StaticResource TextSecondary}"
                   VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right"
                Command="{Binding OpenLogFolderCommand}"
                Background="Transparent" BorderThickness="0"
                Cursor="Hand" VerticalAlignment="Center"
